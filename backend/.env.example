# Copy this file to .env and fill in the values
# Never commit .env to version control

# OpenAI API key — used for text-embedding-3-small
OPENAI_API_KEY=sk-...

# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service role key (from Project Settings > API > service_role)
# WARNING: this key bypasses Row Level Security — keep it secret
SUPABASE_SERVICE_ROLE_KEY=eyJ...
